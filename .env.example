# Root .env.example - copy to .env in each sub-directory

# ─── Backend ──────────────────────────────────────────────────────────────────
# See backend/.env.example for all backend variables

# ─── Frontend ─────────────────────────────────────────────────────────────────
# See frontend/.env.example for all frontend variables

# ─── Docker Compose ───────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_in_production
JWT_ACCESS_SECRET=change_this_in_production_access_32chars
JWT_REFRESH_SECRET=change_this_in_production_refresh_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost
